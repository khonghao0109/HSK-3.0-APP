generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int                @id @default(autoincrement())
  email          String             @unique
  password       String
  role           Role               @default(user)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  progresses     Progress[]
  results        Result[]
  userWords      UserWord[]
  wordProgresses UserWordProgress[]
}

model Level {
  id         Int         @id @default(autoincrement())
  name       String @unique  
  orderIndex Int
  lessons    Lesson[]
  questions  Question[]
  stories    Story[]
  tests      Test[]
  wordLevels WordLevel[]
}

model Lesson {
  id          Int          @id @default(autoincrement())
  levelId     Int
  title       String
  description String?
  orderIndex  Int
  slug        String       @unique
  level       Level        @relation(fields: [levelId], references: [id])
  lessonWords LessonWord[]
  progresses  Progress[]
  topics      Topic[]
}

model Topic {
  id         Int    @id @default(autoincrement())
  lessonId   Int
  title      String
  content    String
  orderIndex Int
  lesson     Lesson @relation(fields: [lessonId], references: [id])
}

model Story {
  id      Int    @id @default(autoincrement())
  levelId Int
  title   String
  content String
  slug    String @unique
  level   Level  @relation(fields: [levelId], references: [id])
}

model Question {
  id            Int            @id @default(autoincrement())
  content       String
  type          QuestionType
  skill         Skill
  answers       Json
  correctAnswer Json
  explanation   String?
  levelId       Int
  audioUrl      String?
  deletedAt     DateTime?
  level         Level          @relation(fields: [levelId], references: [id])
  testQuestions TestQuestion[]

  @@index([levelId])
  @@index([skill])
}

model Test {
  id        Int            @id @default(autoincrement())
  levelId   Int
  title     String
  duration  Int
  deletedAt DateTime?
  results   Result[]
  level     Level          @relation(fields: [levelId], references: [id])
  questions TestQuestion[]
}

model TestQuestion {
  id         Int      @id @default(autoincrement())
  testId     Int
  questionId Int
  orderIndex Int
  question   Question @relation(fields: [questionId], references: [id])
  test       Test     @relation(fields: [testId], references: [id])

  @@unique([testId, questionId])
}

model Result {
  id         Int      @id @default(autoincrement())
  userId     Int
  testId     Int
  score      Int
  detailJson Json
  createdAt  DateTime @default(now())
  test       Test     @relation(fields: [testId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Word {
  id          Int                @id @default(autoincrement())
  hanzi       String
  pinyin      String
  pinyinTone  String?   // 🔥 thêm dòng này
  example     String?
  lessonWords LessonWord[]
  userWords   UserWord[]
  progresses  UserWordProgress[]
  wordLevels  WordLevel[]
  meanings    WordMeaning[]
  traditional String?
  isPure      Boolean @default(true)

  @@index([hanzi])
  @@index([pinyin])
  @@unique([hanzi, pinyin]) // 🔥 BẮT BUỘC
}

model WordMeaning {
  id        Int    @id @default(autoincrement())
  wordId    Int
  meaningEn String
  meaningVi String?
  word      Word   @relation(fields: [wordId], references: [id])

  @@index([wordId])
}

model WordLevel {
  id      Int   @id @default(autoincrement())
  wordId  Int
  levelId Int
  level   Level @relation(fields: [levelId], references: [id])
  word    Word  @relation(fields: [wordId], references: [id])

  @@unique([wordId, levelId])
  @@index([wordId])
  @@index([levelId])
}

model LessonWord {
  id       Int    @id @default(autoincrement())
  lessonId Int
  wordId   Int
  lesson   Lesson @relation(fields: [lessonId], references: [id])
  word     Word   @relation(fields: [wordId], references: [id])

  @@unique([lessonId, wordId])
}

model UserWord {
  id        Int      @id @default(autoincrement())
  userId    Int
  wordId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  word      Word     @relation(fields: [wordId], references: [id])

  @@unique([userId, wordId])
}

model Progress {
  id        Int            @id @default(autoincrement())
  userId    Int
  lessonId  Int
  status    ProgressStatus
  score     Int?
  updatedAt DateTime       @updatedAt
  lesson    Lesson         @relation(fields: [lessonId], references: [id])
  user      User           @relation(fields: [userId], references: [id])

  @@unique([userId, lessonId])
}

model UserWordProgress {
  id     Int                @id @default(autoincrement())
  userId Int
  wordId Int
  status WordProgressStatus
  user   User               @relation(fields: [userId], references: [id])
  word   Word               @relation(fields: [wordId], references: [id])

  @@unique([userId, wordId])
}

enum Role {
  user
  admin
}

enum QuestionType {
  mcq
  listening
  reading
}

enum Skill {
  listening
  reading
  writing
}

enum ProgressStatus {
  not_started
  learning
  done
}

enum WordProgressStatus {
  learning
  done
}
